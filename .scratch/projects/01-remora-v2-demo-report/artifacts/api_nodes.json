[{"node_id":".","node_type":"directory","name":".","full_name":".","file_path":".","start_line":0,"end_line":0,"start_byte":0,"end_byte":0,"source_code":"","source_hash":"25a6634263c1b1f6fc4697a04e2b9904ea4b042a89af59dc93ec1f5d44848a26","parent_id":null,"status":"idle","bundle_name":"directory-agent"},{"node_id":"/home/andrew/Documents/Projects/remora-test/src/api/orders.py::create_order","node_type":"function","name":"create_order","full_name":"create_order","file_path":"/home/andrew/Documents/Projects/remora-test/src/api/orders.py","start_line":7,"end_line":16,"start_byte":197,"end_byte":616,"source_code":"def create_order(request: OrderRequest) -> OrderSummary:\n    \"\"\"Create an order summary with tier discount and tax.\"\"\"\n    subtotal = compute_total(request.item_prices)\n    discount = discount_for_tier(request.user_tier, subtotal)\n    taxed_total = apply_tax(subtotal - discount, request.tax_rate)\n    return OrderSummary(\n        subtotal=subtotal,\n        discount=discount,\n        total=round(taxed_total, 2),\n    )","source_hash":"bd8b090bb27fcad67941503b245c0702396b26ea90139d256f06d4a25146bf85","parent_id":"src/api","status":"idle","bundle_name":"code-agent"},{"node_id":"/home/andrew/Documents/Projects/remora-test/src/models/order.py::OrderRequest","node_type":"class","name":"OrderRequest","full_name":"OrderRequest","file_path":"/home/andrew/Documents/Projects/remora-test/src/models/order.py","start_line":4,"end_line":8,"start_byte":36,"end_byte":154,"source_code":"@dataclass(frozen=True)\nclass OrderRequest:\n    user_tier: str\n    item_prices: list[float]\n    tax_rate: float = 0.07","source_hash":"15ea5145c3b66dfb1dcc4eb94e1b0e09a101b3ff84849654d720ff612769d66f","parent_id":"src/models","status":"idle","bundle_name":"code-agent"},{"node_id":"/home/andrew/Documents/Projects/remora-test/src/models/order.py::OrderRequest.OrderRequest","node_type":"class","name":"OrderRequest","full_name":"OrderRequest.OrderRequest","file_path":"/home/andrew/Doc