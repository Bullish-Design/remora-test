nt_for_tier(tier: str, subtotal: float) -> float:\n    \"\"\"Return discount amount based on account tier.\"\"\"\n    normalized = tier.lower().strip()\n    if normalized == \"gold\":\n        return subtotal * 0.15\n    if normalized == \"silver\":\n        return subtotal * 0.05\n    return 0.0","source_hash":"8478d425e6fce725f690f88c1d7b1dcfc7651fdc7613d1710769b2a757cafbb0","parent_id":"src/services","status":"idle","bundle_name":"code-agent"},{"node_id":"/home/andrew/Documents/Projects/remora-test/src/services/fraud.py::risk_score","node_type":"function","name":"risk_score","full_name":"risk_score","file_path":"/home/andrew/Documents/Projects/remora-test/src/services/fraud.py","start_line":1,"end_line":5,"start_byte":0,"end_byte":187,"source_code":"def risk_score(amount: float, user_tier: str) -> float:\n    base = amount / 100.0\n    if user_tier.lower().strip() == \"gold\":\n        return max(0.0, base - 0.2)\n    return min(1.0, base)","source_hash":"2921e9f535cfa4b810802b1f6abb85d64875a5e9a3a2289a8017546c3b7b3754","parent_id":"src/services","status":"idle","bundle_name":"code-agent"},{"node_id":"/home/andrew/Documents/Projects/remora-test/src/services/fulfillment/allocator.py::choose_warehouse","node_type":"function","name":"choose_warehouse","full_name":"choose_warehouse","file_path":"/home/andrew/Documents/Projects/remora-test/src/services/fulfillment/allocator.py","start_line":1,"end_line":7,"start_byte":0,"end_byte":292,"source_code":"def choose_warehouse(postal_code: str) -> str:\n    \"\"\"Very simple warehouse allocation logic for demo purposes.\"\"\"\n    if postal_code.startswith((\"0\", \"1\", \"2\", \"3\")):\n        return \"east-coast\"\n    if postal_code.startswith((\"7\", \"8\", \"9\")):\n        return \"west-coast\"\n    return \"central\"","source_hash":"adeb506dbf13f1a1bea74c4fe2de3b4577b83608b5d76ebdc68fa97284e38303","parent_id":"src/services/fulfillment","status":"idle","bundle_name":"code-agent"},{"node_id":"/home/andrew/Documents/Projects/remora-test/src/services/pricing.py::compute_total","node_type":"function","name":"compute_total","full_name":"compute_total","file_path":"/home/andrew/Documents/Projects/remora-test/src/services/pricing.py","start_line":1,"end_line":4,"start_byte":0,"end_byte":159,"source_code":"def compute_total(item_prices: list[float]) -> float:\n    subtotal = sum(item_prices)\n    # Guard against tiny floating artifacts\n    return round(subtotal, 2)","source_hash":"1bdae8ba3334443319039e6b93258e02fe4c76f28702312b44f7d445bb5d54a7","parent_id":"src/services","status":"idle","bundle_name":"code-agent"},{"node_id":"/home/andrew/Documents/Projects/remora-test/src/services/tax.py::apply_tax","node_type":"function","name":"apply_tax","full_name":"apply_tax","file_path":"/home/andrew/Documents/Projects/remora-test/src/services/tax.py","start_line":1,"end_line":3,"start_byte":0,"end_byte":152,"source_code":"def apply_tax(amount: float, tax_rate: float = 0.07) -> float:\n    \"\"\"Apply tax percentage to a monetary amount.\"\"\"\n    return amount * (1.0 + tax_rate)","source_hash":"61eec3f77b9c9a02353c1011c6f2979d4f71343e8d59fa57c1ffdd4beb799eca","parent_id":"src/services","status":"idle","bundle_name":"code-agent"},{"node_id":"/home/andrew/Documents/Projects/remora-test/src/utils/money.py::format_usd","node_type":"function","name":"format_usd","full_name":"format_usd","file_path":"/home/andrew/Documents/Projects/remora-test/src/utils/money.py","start_line":1,"end_line":2,"start_byte":0,"end_byte":63,"source_code":"def format_usd(value: float) -> str:\n    return f\"${value:.2f}\"","source_hash":"241f3aa2b11958d64fac59a4c8453aa5e4ffdc9141a17952da6aada12c99b9c9","parent_id":"src/utils","status":"idle","bundle_name":"code-agent"},{"node_id":"src","node_type":"directory","name":"src","full_name":"src","file_path":"src","start_line":0,"end_line":0,"start_byte":0,"end_byte":0,"source_code":"","source_hash":"108e1cebe939ce9d402de1a9c9f0697deb92e267fd94fe2b05d29a33176a01e2","parent_id":